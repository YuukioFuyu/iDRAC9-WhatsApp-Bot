# ══════════════════════════════════════════════════════
# iDRAC9 WhatsApp Bot — MikroTik Container Edition
# ══════════════════════════════════════════════════════
# Konfigurasi khusus untuk deployment di MikroTik Container.
# Semua service (Node.js + Python + PostgreSQL) berjalan
# dalam satu container — tidak perlu Docker Compose stack.
#
# Copy file ini ke .env dan isi kredensial asli Anda:
#   cp .env.mikrotik.example .env

# ──────────────────────────────────────────────────────
# APP GENERAL
# ──────────────────────────────────────────────────────
APP_PORT=3000
APP_HOST=0.0.0.0
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=24h
LOG_LEVEL=info
TZ=Asia/Jakarta

# ──────────────────────────────────────────────────────
# ADMIN CREDENTIALS
# ──────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ──────────────────────────────────────────────────────
# iDRAC / REDFISH (harus dikonfigurasi)
# ──────────────────────────────────────────────────────
IDRAC_HOST=https://192.168.1.100
IDRAC_USERNAME=root
IDRAC_PASSWORD=calvin
IDRAC_VERIFY_SSL=false
IDRAC_TIMEOUT=30
IDRAC_SESSION_TTL=1800

# ──────────────────────────────────────────────────────
# PYTHON API (INTERNAL — jangan ubah)
# Berjalan di dalam container yang sama via supervisord
# ──────────────────────────────────────────────────────
PY_API_URL=http://127.0.0.1:8000
PY_API_PORT=8000
PY_API_HOST=127.0.0.1

# ──────────────────────────────────────────────────────
# REDIS (OPTIONAL — Server Eksternal)
# Redis tidak termasuk dalam container ini.
# Jika digunakan, arahkan ke server Redis eksternal.
# ──────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=192.168.1.xxx
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=idrac:

# ──────────────────────────────────────────────────────
# WHATSAPP
# ──────────────────────────────────────────────────────
WA_SESSION_PATH=/data/sessions
WA_ALLOWED_NUMBERS=628xxxxxxxxxx
WA_COMMAND_PREFIX=
WA_RATE_LIMIT=10

# ──────────────────────────────────────────────────────
# DATABASE — PostgreSQL Internal (JANGAN UBAH)
# PostgreSQL berjalan di dalam container yang sama.
# Port 5432 terbuka untuk backup/restore via pg_dump.
# ──────────────────────────────────────────────────────
# External PG tidak digunakan di MikroTik edition
PG_HOST=
PG_PORT=
PG_DATABASE=
PG_USERNAME=
PG_PASSWORD=

# Internal PG (auto-configured via init-postgres.sh)
MEM_PG_HOST=127.0.0.1
MEM_PG_PORT=5432
MEM_PG_DATABASE=erina_memories
MEM_PG_USERNAME=erina
MEM_PG_PASSWORD=dellemcr640

# ──────────────────────────────────────────────────────
# ALERT SYSTEM
# ──────────────────────────────────────────────────────
ALERT_POLL_INTERVAL=60
ALERT_TEMP_THRESHOLD=75
ALERT_ENABLED=true

# ──────────────────────────────────────────────────────
# ERINA AI (HuggingFace Spaces)
# ──────────────────────────────────────────────────────
ERINA_ENABLED=true
ERINA_HF_TOKEN=hf_your_huggingface_token_here
ERINA_HF_SPACE=Yuuki0/Erina-Delvra-Foren
ERINA_TIMEOUT=180000
ERINA_MAX_TOKENS=512
ERINA_TEMPERATURE=0.7

# ──────────────────────────────────────────────────────
# RAG MEMORY (pgvector — menggunakan Internal PG)
# ──────────────────────────────────────────────────────
ERINA_MEMORY_LIMIT=5
ERINA_RECENT_CONTEXT=3
