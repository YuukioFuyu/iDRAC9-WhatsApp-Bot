# ══════════════════════════════════════════
# iDRAC9 WhatsApp Bot — Environment Config
# ══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────
# APP GENERAL
# ──────────────────────────────────────────
NODE_ENV=production
APP_PORT=3000
APP_HOST=0.0.0.0
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=24h
LOG_LEVEL=info

# ──────────────────────────────────────────
# ADMIN CREDENTIALS
# ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ──────────────────────────────────────────
# iDRAC / REDFISH (Bootstrap — default server)
# ──────────────────────────────────────────
IDRAC_HOST=https://192.168.1.100
IDRAC_USERNAME=root
IDRAC_PASSWORD=calvin
IDRAC_VERIFY_SSL=false
IDRAC_TIMEOUT=30
IDRAC_SESSION_TTL=1800

# ──────────────────────────────────────────
# PYTHON API
# ──────────────────────────────────────────
# URL tempat Node.js menghubungi Python API.
#   Docker Compose : http://python-api:8000 (gunakan nama service Docker)
#   Local dev      : http://localhost:8000  (jika Python berjalan di host)
#   Remote         : http://192.168.x.x:8000 (jika Python di mesin lain)
PY_API_URL=http://python-api:8000
PY_API_PORT=8000
PY_API_HOST=0.0.0.0

# ──────────────────────────────────────────
# REDIS (OPTIONAL)
# ──────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=idrac:

# ──────────────────────────────────────────
# WHATSAPP
# ──────────────────────────────────────────
WA_SESSION_PATH=./sessions
WA_ALLOWED_NUMBERS=628xxxxxxxxxx,628yyyyyyyyyy
WA_COMMAND_PREFIX=
WA_RATE_LIMIT=10

# ──────────────────────────────────────────
# DATABASE — SQLite (always available as fallback)
# ──────────────────────────────────────────
DB_PATH=./data/idrac-bot.db

# ──────────────────────────────────────────
# DATABASE — PostgreSQL (optional, prioritas utama jika dikonfigurasi)
# ──────────────────────────────────────────
PG_HOST=
PG_PORT=5432
PG_DATABASE=idrac_bot
PG_USERNAME=
PG_PASSWORD=

# ──────────────────────────────────────────
# ALERT SYSTEM
# ──────────────────────────────────────────
ALERT_POLL_INTERVAL=60
ALERT_TEMP_THRESHOLD=75
ALERT_ENABLED=true
