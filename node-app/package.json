{
  "name": "idrac9-whatsapp-bot",
  "version": "1.0.0",
  "description": "iDRAC 9 Remote Management via WhatsApp + Web Dashboard",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "css:build": "npx @tailwindcss/cli -i src/public/css/app.css -o src/public/css/output.css --minify",
    "css:watch": "npx @tailwindcss/cli -i src/public/css/app.css -o src/public/css/output.css --watch",
    "build": "npm run css:build"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/formbody": "^8.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/view": "^10.0.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "@xenova/transformers": "^2.17.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "joi": "^17.13.0",
    "node-cron": "^3.0.0",
    "nunjucks": "^3.2.4",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
